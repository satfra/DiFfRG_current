     RowBox[{
      RowBox[{
       RowBox[{"FTerm", "[", "projectorA4", "]"}], "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"fRGA4", "[", "\"\<1-Loop\>\"", "]"}], "[", 
          "\"\<Expression\>\"", "]"}], "/.", 
         RowBox[{"FMakeDiagrammaticRules", "[", "]"}]}], ")"}]}], "//", 
      RowBox[{
       RowBox[{"TBProjectToSymmetricPoint", "[", 
        RowBox[{
        "#", ",", "l1", ",", "p", ",", "p1", ",", "p2", ",", "p3", ",", 
         "p4"}], "]"}], "&"}]}], "//", "Simplify"}]}], ";", 
   "\[IndentingNewLine]", 
   RowBox[{"FlowA4", "=", 
