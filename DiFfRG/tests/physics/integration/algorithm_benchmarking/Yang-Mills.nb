          RowBox[{
           RowBox[{"-", 
            RowBox[{"Zc", "[", 
             SqrtBox[
              RowBox[{"sp", "[", 
               RowBox[{"p2", ",", "p2"}], "]"}]], "]"}]}], 
           RowBox[{"sp", "[", 
            RowBox[{"p2", ",", "p2"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
         
         RowBox[{
          RowBox[{"dressing", "[", 
