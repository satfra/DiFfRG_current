Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fRGA4", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"FTakeDerivatives", "[", 
         RowBox[{"WetterichEquation", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"A", "[", "i1", "]"}], ",", 
            RowBox[{"A", "[", "i2", "]"}], ",", 
            RowBox[{"A", "[", "i3", "]"}], ",", 
            RowBox[{"A", "[", "i4", "]"}]}], "}"}]}], "]"}], "//", 
        "FTruncate"}], "//", "FPlot"}], "//", "FRoute"}], "//", "FPrint"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"projectorA4", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FTerm", "[", 
      RowBox[{"TBGetProjector", "[", 
       RowBox[{"\"\<AAAAClassTrans\>\"", ",", "1", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i1", ",", "i2", ",", "i3", ",", "i4"}], "}"}], "/.", 
         RowBox[{
          RowBox[{"fRGA4", "[", "\"\<1-Loop\>\"", "]"}], "[", 
          "\"\<ExternalIndices\>\"", "]"}]}]}], "]"}], "]"}], "//", 
     RowBox[{
      RowBox[{"TBProjectToSymmetricPoint", "[", 
       RowBox[{
       "#", ",", "l1", ",", "p", ",", "p1", ",", "p2", ",", "p3", ",", "p4"}],
        "]"}], "&"}]}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"traceExprA4", "=", 
   RowBox[{
    RowBox[{"projectorA4", "**", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"fRGA4", "[", "\"\<1-Loop\>\"", "]"}], "[", 
        "\"\<Expression\>\"", "]"}], "/.", 
       RowBox[{"FMakeDiagrammaticRules", "[", "]"}]}], ")"}]}], "//", 
    RowBox[{
     RowBox[{"TBProjectToSymmetricPoint", "[", 
      RowBox[{
      "#", ",", "l1", ",", "p", ",", "p1", ",", "p2", ",", "p3", ",", "p4"}], 
      "]"}], "&"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FlowA4", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"FormTrace", "[", 
         RowBox[{"\"\<ZA4\>\"", ",", "traceExprA4", ",", 
          RowBox[{"{", "}"}], ",", "SP4FormRule"}], "]"}], "//", 
        "dressingRules"}], "//", 
       RowBox[{
        RowBox[{"TBProjectToSymmetricPoint", "[", 
         RowBox[{
         "#", ",", "l1", ",", "p", ",", "p1", ",", "p2", ",", "p3", ",", 
          "p4"}], "]"}], "&"}]}], "//", "SPParam"}], "//", "Simplify"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"MakeKernel", "[", 
  RowBox[{"FlowA4", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"\"\<Name\>\"", "->", "\"\<ZA4\>\""}], ",", "\[IndentingNewLine]", 
   
   RowBox[{"\"\<Integrator\>\"", "->", "\"\<Integrator_p2_4D_3ang\>\""}], ",",
