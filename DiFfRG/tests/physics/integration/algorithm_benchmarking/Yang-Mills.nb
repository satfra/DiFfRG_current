Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SP3Patt", "[", 
    RowBox[{"p1e_", ",", "p2e_", ",", "p3e_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       SqrtBox[
        FractionBox[
         RowBox[{
          RowBox[{"sp", "[", 
           RowBox[{"p1", ",", "p1"}], "]"}], "+", 
          RowBox[{"sp", "[", 
           RowBox[{"p2", ",", "p2"}], "]"}], "+", 
          RowBox[{"sp", "[", 
           RowBox[{"p3", ",", "p3"}], "]"}]}], "3"]], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"p1", ":>", "p1e"}], ",", 
        RowBox[{"p2", ":>", "p2e"}], ",", 
        RowBox[{"p3", ":>", "p3e"}]}], "}"}]}], "//", "UseLorentzLinearity"}],
     "//", "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SP4Patt", "[", 
    RowBox[{"p1e_", ",", "p2e_", ",", "p3e_", ",", "p4e_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       SqrtBox[
        FractionBox[
         RowBox[{
          RowBox[{"sp", "[", 
           RowBox[{"p1", ",", "p1"}], "]"}], "+", 
          RowBox[{"sp", "[", 
           RowBox[{"p2", ",", "p2"}], "]"}], "+", 
          RowBox[{"sp", "[", 
           RowBox[{"p3", ",", "p3"}], "]"}], "+", 
          RowBox[{"sp", "[", 
           RowBox[{"p4", ",", "p4"}], "]"}]}], "4"]], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"p1", ":>", "p1e"}], ",", 
        RowBox[{"p2", ":>", "p2e"}], ",", 
        RowBox[{"p3", ":>", "p3e"}], ",", 
        RowBox[{"p4", ":>", "p4e"}]}], "}"}]}], "//", "UseLorentzLinearity"}],
     "//", "FullSimplify"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.93679400727847*^9, 3.936794078697687*^9}, {
   3.936796737944875*^9, 3.936796758125753*^9}, {3.937575090028185*^9, 
