       RowBox[{
        RowBox[{"TBProjectToSymmetricPoint", "[", 
         RowBox[{"#", ",", "l1", ",", "p", ",", "p1", ",", "p2", ",", "p3"}], 
         "]"}], "&"}]}], "//", "SPParam"}], "//", "Simplify"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
