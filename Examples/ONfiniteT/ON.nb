    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "m2Pi"}], "-", 
        SuperscriptBox["l1", "2"], "-", 
        RowBox[{"RB", "[", 
         RowBox[{
          SuperscriptBox["k", "2"], ",", 
          SuperscriptBox["l1", "2"]}], "]"}]}], "<", "0"}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "m2Sigma"}], "-", 
        SuperscriptBox["l1", "2"], "-", 
        RowBox[{"RB", "[", 
         RowBox[{
          SuperscriptBox["k", "2"], ",", 
          SuperscriptBox["l1", "2"]}], "]"}]}], "<", "0"}]}], ",", 
     RowBox[{
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"MatsubaraSum", "[", 
          RowBox[{"#", ",", "l10", ",", "T"}], "]"}], "&"}], ",", "flowV"}], 
       "]"}], "//", "FullSimplify"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
