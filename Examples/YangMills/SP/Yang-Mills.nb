Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fRGA3", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"FTakeDerivatives", "[", 
         RowBox[{"WetterichEquation", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"A", "[", "i1", "]"}], ",", 
            RowBox[{"A", "[", "i2", "]"}], ",", 
            RowBox[{"A", "[", "i3", "]"}]}], "}"}]}], "]"}], "//", 
        "FTruncate"}], "//", "FPlot"}], "//", "FRoute"}], "//", "FPrint"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"projectorA3", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FTerm", "[", 
      RowBox[{"TBGetProjector", "[", 
       RowBox[{"\"\<AAAClassTrans\>\"", ",", "1", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i1", ",", "i2", ",", "i3"}], "}"}], "/.", 
         RowBox[{
          RowBox[{"fRGA3", "[", "\"\<1-Loop\>\"", "]"}], "[", 
          "\"\<ExternalIndices\>\"", "]"}]}]}], "]"}], "]"}], "//", 
     RowBox[{
      RowBox[{"TBProjectToSymmetricPoint", "[", 
       RowBox[{"#", ",", "l1", ",", "p", ",", "p1", ",", "p2", ",", "p3"}], 
       "]"}], "&"}]}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"traceExprA3", "=", 
   RowBox[{"projectorA3", "**", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"fRGA3", "[", "\"\<1-Loop\>\"", "]"}], "[", 
       "\"\<Expression\>\"", "]"}], "/.", 
      RowBox[{"FMakeDiagrammaticRules", "[", "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FlowA3", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"FormTrace", "[", 
         RowBox[{"\"\<ZA3\>\"", ",", "traceExprA3", ",", 
          RowBox[{"{", "}"}], ",", "SP3FormRule"}], "]"}], "//", 
