    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalGamma]\[Sigma]\[Sigma]", "[", 
           RowBox[{"{", 
