            RowBox[{"A", "[", "i2", "]"}], ",", 
            RowBox[{"A", "[", "i3", "]"}], ",", 
            RowBox[{"A", "[", "i4", "]"}]}], "}"}]}], "]"}], "//", 
        "FTruncate"}], "//", "FPlot"}], "//", "FRoute"}], "//", "FPrint"}]}], 
   ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"projectorA4", "=", 
