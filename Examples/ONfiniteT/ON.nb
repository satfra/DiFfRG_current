           RowBox[{"-", "p"}], ",", "a1"}], "}"}], "]"}]}], "//.", 
       "FeynmanRules"}], "//", "FormTrace"}], "//", "ExpandScalarProducts"}], 
    "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
