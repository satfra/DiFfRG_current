 RowBox[{
  RowBox[{"flowV", "=", 
   RowBox[{"FormTrace", "[", 
    RowBox[{
     RowBox[{"flowV", "[", "\"\<1-Loop\>\"", "]"}], "[", "\"\<Expression\>\"",
      "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"flowV", "=", 
   RowBox[{
    RowBox[{"ExpandScalarProductsFiniteT", "[", "flowV", "]"}], "//", 
    RowBox[{
     RowBox[{"SimplifyAllMomenta", "[", 
      RowBox[{"l1", ",", "#"}], "]"}], "&"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"flowV", "=", 
