          RowBox[{"R\[Sigma]\[Sigma]", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "p"}], ",", "p"}], "}"}], "]"}]}], ")"}], 
        RowBox[{"G\[Sigma]\[Sigma]", "[", 
         RowBox[{"{", 
          RowBox[{"p", ",", 
           RowBox[{"-", "p"}]}], "}"}], "]"}]}], "//.", "FeynmanRules"}], "//",
       "FormTrace"}], "//", "ExpandScalarProducts"}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
