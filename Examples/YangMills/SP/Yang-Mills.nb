        "FTruncate"}], "//", "FPlot"}], "//", "FRoute"}], "//", "FPrint"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"traceExprcbc", "=", 
